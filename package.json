{
  "name": "@ablo/sync-engine",
  "version": "0.4.0",
  "description": "Real-time sync engine for TypeScript apps. Schema-driven, offline-first, with React hooks and AI agent support.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./config": {
      "source": "./src/config/index.ts",
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.js",
      "default": "./src/config/index.ts"
    },
    "./core": {
      "source": "./src/core/index.ts",
      "types": "./src/core/index.ts",
      "import": "./dist/core/index.js",
      "default": "./src/core/index.ts"
    },
    "./client": {
      "source": "./src/client/index.ts",
      "types": "./src/client/index.ts",
      "import": "./dist/client/index.js",
      "default": "./src/client/index.ts"
    },
    "./agent": {
      "source": "./src/agent/index.ts",
      "types": "./src/agent/index.ts",
      "import": "./dist/agent/index.js",
      "default": "./src/agent/index.ts"
    },
    "./mesh": {
      "source": "./src/mesh/index.ts",
      "types": "./src/mesh/index.ts",
      "import": "./dist/mesh/index.js",
      "default": "./src/mesh/index.ts"
    },
    "./schema": {
      "source": "./src/schema/index.ts",
      "types": "./src/schema/index.ts",
      "import": "./dist/schema/index.js",
      "default": "./src/schema/index.ts"
    },
    "./react": {
      "source": "./src/react/index.ts",
      "types": "./src/react/index.ts",
      "import": "./dist/react/index.js",
      "default": "./src/react/index.ts"
    },
    "./types": {
      "source": "./src/types.ts",
      "types": "./src/types.ts",
      "import": "./dist/types.js",
      "default": "./src/types.ts"
    },
    "./testing": {
      "source": "./src/testing/index.ts",
      "types": "./src/testing/index.ts",
      "import": "./dist/testing/index.js",
      "default": "./src/testing/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:contract": "jest --testPathPattern=__tests__/contract",
    "test:property": "jest --testPathPattern=__tests__/property",
    "test:coverage": "jest --coverage",
    "test:e2e": "E2E_TEST=true jest --config jest.e2e.config.ts",
    "test:e2e:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:e2e:down": "docker compose -f docker-compose.test.yml down -v",
    "test:e2e:run": "npm run test:e2e:up && npm run test:e2e; npm run test:e2e:down"
  },
  "keywords": [
    "sync-engine",
    "real-time",
    "offline-first",
    "websocket",
    "react",
    "mobx",
    "typescript",
    "schema",
    "sync",
    "multiplayer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abloatai/ablo.git"
  },
  "homepage": "https://github.com/abloatai/ablo#readme",
  "bugs": {
    "url": "https://github.com/abloatai/ablo/issues"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "mobx": "^6.13.7",
    "mobx-react-lite": "^4.0.0",
    "zod": "^3.24.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mobx": "^6.13.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}
